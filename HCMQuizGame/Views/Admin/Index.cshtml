@{
    ViewData["Title"] = "Admin";
}

<style>

    body {
        background: linear-gradient(to bottom right, #fff5f5, white);
        font-family: Arial;
    }

    .admin-card {
        width: 700px;
        margin: auto;
        margin-top: 120px;
        background: white;
        padding: 60px;
        border-radius: 30px;
        text-align: center;
        box-shadow: 0 10px 40px rgba(0,0,0,0.15);
    }

    .title {
        font-size: 55px;
        font-weight: bold;
        color: #c40000;
    }

    .start-btn {
        margin-top: 50px;
        width: 100%;
        height: 80px;
        border: none;
        border-radius: 50px;
        background: linear-gradient(to right,#ff0000,#b30000);
        color: white;
        font-size: 35px;
        font-weight: bold;
    }

</style>

<div class="admin-card">

    <div class="title">
        🎮 ADMIN PANEL
    </div>
    <div id="playerCountBox"
         style="
        margin-top:30px;
        font-size:35px;
        font-weight:bold;
        color:#c40000;">

        👥 Số người tham gia:
        <span id="playerCount">0</span>

    </div>

    <button class="start-btn"
            onclick="startGame()">

        BẮT ĐẦU GAME

    </button>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

<script>

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/quizHub")
        .build();

    async function startConnection()
    {
        try
        {
            await connection.start();

            console.log("SignalR Connected");
        }
        catch(err)
        {
            console.log(err);
        }
    }

    startConnection();

    function startGame()
    {
        connection.invoke("StartGame");
    }

    connection.on("UpdatePlayerCount", function (count) {

        document.getElementById("playerCount")
            .innerText = count;

    });

</script>

