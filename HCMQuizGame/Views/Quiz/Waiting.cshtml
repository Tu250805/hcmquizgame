@{
    ViewData["Title"] = "Phòng Chờ";
}

<style>
    html, body {
        overflow-x: hidden !important;
        max-width: 100% !important;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        padding: 0;
        overflow: hidden;
        background: linear-gradient(to bottom right, #fff5f5, #ffffff);
        font-family: Arial, sans-serif;
    }

    .bg-left {
        position: fixed;
        left: -180px;
        top: 80px;
        width: 550px;
        height: 550px;
        background: #d90000;
        border-radius: 45%;
        transform: rotate(20deg);
        opacity: 0.95;
        z-index: -1;
    }

    .bg-right {
        position: fixed;
        right: -220px;
        bottom: -180px;
        width: 600px;
        height: 600px;
        background: #d90000;
        border-radius: 45%;
        transform: rotate(-20deg);
        z-index: -1;
    }

    .waiting-container {
        width: 750px;
        max-width: 92%;
        margin: auto;
        margin-top: 70px;
        background: white;
        border-radius: 35px;
        padding: 50px;
        text-align: center;
        box-shadow: 0 10px 45px rgba(0,0,0,0.18);
        border: 3px solid #ffd4d4;
    }

    .flag-img {
        width: 130px;
        margin-bottom: 20px;
    }

    .mini-text {
        color: #c40000;
        font-size: 38px;
        font-family: cursive;
        margin-bottom: 10px;
    }

    .main-title {
        color: #c40000;
        font-size: 58px;
        font-weight: bold;
        line-height: 1.1;
        margin-bottom: 20px;
    }

    .welcome-text {
        font-size: 35px;
        font-weight: bold;
        color: #222;
        margin-top: 30px;
        margin-bottom: 20px;
    }

    .waiting-text {
        color: #d90000;
        font-size: 30px;
        font-weight: bold;
        margin-top: 20px;
        animation: pulse 1.3s infinite;
    }

    .waiting-container {
        width: 92% !important;
        padding: 25px !important;
    }

    .main-title {
        font-size: 36px !important;
    }

    .welcome-text {
        font-size: 24px !important;
    }

    .waiting-text {
        font-size: 22px !important;
    }

    .bg-left,
    .bg-right {
        width: 320px;
        height: 320px;
    }

    @@keyframes pulse {

        0% {
            opacity: 0.3;
            transform: scale(0.98);
        }

        50% {
            opacity: 1;
            transform: scale(1);
        }

        100% {
            opacity: 0.3;
            transform: scale(0.98);
        }
    }

    .loading-dots span {
        animation: blink 1.4s infinite;
        font-size: 35px;
    }

        .loading-dots span:nth-child(2) {
            animation-delay: 0.2s;
        }

        .loading-dots span:nth-child(3) {
            animation-delay: 0.4s;
        }

    @@keyframes blink {

        0% {
            opacity: 0.2;
        }

        50% {
            opacity: 1;
        }

        100% {
            opacity: 0.2;
        }
    }

    .footer-text {
        margin-top: 50px;
        color: #c40000;
        font-size: 18px;
        font-weight: bold;
    }

    .top-right-birds {
        position: fixed;
        top: 100px;
        right: 120px;
        font-size: 45px;
        color: #d90000;
        opacity: 0.8;
    }

    @@media (max-width: 768px) {

        body {
            overflow-x: hidden;
        }

        .waiting-card,
        .main-card,
        .container {
            width: 92% !important;
            margin: auto !important;
            padding: 20px !important;
        }

        h1, h2 {
            font-size: 32px !important;
        }

        .player-name,
        .status-text {
            font-size: 22px !important;
        }

        img {
            max-width: 100% !important;
            height: auto !important;
        }
    }

</style>

<div class="bg-left"></div>
<div class="bg-right"></div>

<div class="top-right-birds">
    🕊️ 🕊️
</div>

<div class="waiting-container">

    <img class="flag-img"
         src="https://upload.wikimedia.org/wikipedia/commons/2/21/Flag_of_Vietnam.svg" />

    <div class="mini-text">
        Mini Game
    </div>

    <div class="main-title">
        TƯ TƯỞNG <br />
        HỒ CHÍ MINH
    </div>

    <div class="welcome-text">
        👤 Xin chào, @ViewBag.PlayerName
    </div>
    <div style="font-size:28px;
            color:#c40000;
            font-weight:bold;
            margin-top:30px;">

        🎮 Đang có:
        <span id="playerCount">0</span>
        người tham gia

    </div>
    <div class="waiting-text">

        ĐANG CHỜ QUẢN TRÒ BẮT ĐẦU

        <div class="loading-dots">
            <span>.</span>
            <span>.</span>
            <span>.</span>
        </div>

    </div>

    <div class="footer-text">
        🇻🇳 HỌC TẬP - RÈN LUYỆN - CỐNG HIẾN 🇻🇳
    </div>

</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

<script>

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/quizHub")
        .build();

    connection.start().then(function () {

        connection.invoke("JoinGame");

    });

    connection.on("UpdatePlayerCount", function (count) {

        document.getElementById("playerCount")
            .innerText = count;

    });
        connection.on("GameStarted", function () {

        window.location.href = "/Quiz/Play";

    });
</script>
