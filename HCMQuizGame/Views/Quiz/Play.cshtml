
@{
    ViewData["Title"] = "Thi";
}


<style>
    html, body {
        overflow-x: hidden !important;
        max-width: 100% !important;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        padding: 0;
        background: linear-gradient(rgba(120,0,0,0.88), rgba(80,0,0,0.9)), url('https://images.unsplash.com/photo-1521295121783-8a321d551ad2?q=80&w=2070');
        background-size: cover;
        background-position: center;
        min-height: 100vh;
        font-family: Arial;
        overflow-x: hidden;
    }

    .quiz-box {
        width: 1100px;
        max-width: 95%;
        margin: auto;
        margin-top: 40px;
        background: rgba(255,255,255,0.96);
        border-radius: 35px;
        padding: 45px;
        box-shadow: 0 15px 50px rgba(0,0,0,0.35);
        backdrop-filter: blur(10px);
        border: 4px solid rgba(255,215,0,0.3);
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 35px;
    }

    .question-number {
        font-size: 34px;
        font-weight: bold;
        color: #c40000;
    }

    .timer {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: linear-gradient(135deg,#ff0000,#b30000);
        display: flex;
        justify-content: center;
        align-items: center;
        color: white;
        font-size: 40px;
        font-weight: bold;
        box-shadow: 0 0 25px rgba(255,0,0,0.6);
        animation: pulse 1s infinite;
    }

    @@keyframes pulse {

        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.08);
        }

        100% {
            transform: scale(1);
        }
    }

    .question-content {
        background: linear-gradient(to right,#fff5f5,#ffffff);
        border-left: 10px solid #d40000;
        padding: 35px;
        border-radius: 25px;
        font-size: 30px;
        font-weight: bold;
        color: #222;
        line-height: 1.7;
        margin-bottom: 35px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    }

    .answers {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 25px;
    }

    .answer-btn {
        border: none;
        border-radius: 25px;
        min-height: 130px;
        padding: 25px;
        font-size: 23px;
        font-weight: bold;
        text-align: left;
        transition: 0.3s;
        line-height: 1.6;
        cursor: pointer;
        box-shadow: 0 5px 15px rgba(0,0,0,0.12);
        position: relative;
        overflow: hidden;
    }

        .answer-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: rgba(255,255,255,0.3);
            transition: 0.5s;
        }

        .answer-btn:hover::before {
            left: 100%;
        }

        .answer-btn:hover {
            transform: translateY(-6px) scale(1.02);
            box-shadow: 0 12px 25px rgba(0,0,0,0.2);
        }

    #btnA {
        background: linear-gradient(135deg,#ff4d4d,#cc0000);
        color: white;
    }

    #btnB {
        background: linear-gradient(135deg,#ffd633,#e6b800);
        color: black;
    }

    #btnC {
        background: linear-gradient(135deg,#4da6ff,#0066cc);
        color: white;
    }

    #btnD {
        background: linear-gradient(135deg,#66cc66,#248f24);
        color: white;
    }

    .player-info {
        text-align: center;
        color: white;
        font-size: 28px;
        font-weight: bold;
        margin-top: 25px;
        text-shadow: 0 3px 10px rgba(0,0,0,0.4);
    }

    .quiz-box {
        width: 95% !important;
        padding: 20px !important;
    }

    .answers {
        grid-template-columns: 1fr !important;
    }

    .question-content {
        font-size: 22px !important;
    }

    .timer {
        width: 70px;
        height: 70px;
        font-size: 28px;
    }

    @@media (max-width: 768px) {

        body {
            overflow-x: hidden;
        }

        .container,
        .container-fluid,
        .question-card,
        .quiz-card {
            width: 100% !important;
            max-width: 100% !important;
            padding-left: 10px !important;
            padding-right: 10px !important;
            margin: auto !important;
        }

        h1, h2, h3 {
            font-size: 28px !important;
        }

        .question-text {
            font-size: 22px !important;
            line-height: 1.5;
        }

        .answer-btn,
        button {
            width: 100% !important;
            font-size: 20px !important;
            padding: 14px !important;
            margin-bottom: 12px !important;
        }

        img {
            max-width: 100% !important;
            height: auto !important;
        }
    }

</style>



<div class="quiz-box">

    <div>

        <span class="question-number"
              id="questionNumber">

            Câu 1/20

        </span>

        <span class="timer"
              id="timer">

            20

        </span>

    </div>

    <div class="question-content"
         id="questionContent">
    </div>

    <button class="answer-btn"
            id="btnA"
            onclick="chooseAnswer('A',this)">
    </button>

    <button class="answer-btn"
            id="btnB"
            onclick="chooseAnswer('B',this)">
    </button>

    <button class="answer-btn"
            id="btnC"
            onclick="chooseAnswer('C',this)">
    </button>

    <button class="answer-btn"
            id="btnD"
            onclick="chooseAnswer('D',this)">
    </button>

</div>
<input type="hidden"
       id="playerName"
       value="@ViewBag.PlayerName" />
<script>

    let currentQuestion = 0;

    let score = 0;

    let totalTime = 0;

    let answered = false;

    let timer;

    const questions = [

