    loadQuestion();

    function loadQuestion()
    {
        answered = false;

        document.getElementById("questionNumber")
            .innerText =
            "Câu " + (currentQuestion + 1) + "/" + questions.length;

        document.getElementById("questionContent")
            .innerText =
            questions[currentQuestion].question;

        document.getElementById("btnA")
            .innerText =
            "A. " + questions[currentQuestion].A;

        document.getElementById("btnB")
            .innerText =
            "B. " + questions[currentQuestion].B;

        document.getElementById("btnC")
            .innerText =
            "C. " + questions[currentQuestion].C;

        document.getElementById("btnD")
            .innerText =
            "D. " + questions[currentQuestion].D;

        resetButtons();

        startTimer();
    }

    function startTimer()
    {
        let time = 20;

        document.getElementById("timer")
            .innerText = time;

        clearInterval(timer);

        timer = setInterval(function () {

            time--;

            totalTime++;

            document.getElementById("timer")
                .innerText = time;

            if(time <= 0)
            {
                clearInterval(timer);

                nextQuestion();
            }

        },1000);
    }

    function chooseAnswer(answer,button)
    {
        if(answered) return;

        answered = true;

        clearInterval(timer);

        let correct =
            questions[currentQuestion].correct;

        if(answer == correct)
        {
            score += 0.5;

            button.style.background = "green";
            button.style.color = "black";
        }
        else
        {
            button.style.background = "red";
            button.style.color = "white";
        }

        setTimeout(function () {

            nextQuestion();

        },3000);
    }

      function nextQuestion()
    {
        currentQuestion++;

        if(currentQuestion >= questions.length)
        {
            submitResult();

            return;
        }

        loadQuestion();
    }

    function resetButtons()
    {
        const buttons =
            document.querySelectorAll(".answer-btn");

        buttons.forEach(btn => {

            btn.style.background = "#f3f3f3";

            btn.style.color = "black";

        });
    }
        async function submitResult()
    {
        const playerName =
            document.getElementById("playerName").value;

        await fetch("/Quiz/SubmitResult",
        {
            method: "POST",

            headers:
            {
                "Content-Type":
                "application/x-www-form-urlencoded"
            },

            body:
                `playerName=${playerName}&score=${score}&timeUsed=${totalTime}`
        });

        window.location.href =
            "/Quiz/Leaderboard";
    }
</script>
