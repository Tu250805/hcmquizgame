@{
    ViewData["Title"] = "Tham Gia";
}

<style>

    body {
        background: linear-gradient(to bottom right, #fff5f5, #ffffff);
        overflow-x: hidden;
        margin: 0;
        padding: 0;
    }

    .main-bg {
        position: fixed;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        z-index: -1;
        overflow: hidden;
    }

    .left-wave {
        position: absolute;
        left: -150px;
        top: 120px;
        width: 500px;
        height: 500px;
        background: #d90000;
        border-radius: 45%;
        transform: rotate(20deg);
        opacity: 0.95;
    }

    .right-wave {
        position: absolute;
        right: -200px;
        bottom: -150px;
        width: 500px;
        height: 500px;
        background: #d90000;
        border-radius: 45%;
        transform: rotate(-20deg);
    }

    .join-card {
        width: 600px;
        max-width: 92%;
        background: white;
        margin: auto;
        margin-top: 80px;
        border-radius: 30px;
        padding: 50px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.15);
        text-align: center;
        border: 3px solid #ffd6d6;
        position: relative;
        z-index: 2;
    }

    .main-title {
        color: #c40000;
        font-size: 65px;
        font-weight: bold;
        line-height: 1.1;
        margin-bottom: 15px;
    }

    .mini-text {
        color: #c40000;
        font-size: 40px;
        font-family: cursive;
    }

    .sub-text {
        color: #d35400;
        font-size: 22px;
        margin-bottom: 40px;
    }

    .join-input {
        height: 60px;
        border-radius: 15px;
        border: 2px solid #ffb0b0;
        font-size: 22px;
        padding-left: 20px;
    }

    .join-btn {
        width: 100%;
        height: 65px;
        border: none;
        border-radius: 40px;
        background: linear-gradient(to right, #ff0000, #b30000);
        color: white;
        font-size: 30px;
        font-weight: bold;
        margin-top: 25px;
        transition: 0.3s;
    }

        .join-btn:hover {
            transform: scale(1.03);
        }

    .footer-text {
        margin-top: 40px;
        color: #c40000;
        font-weight: bold;
        font-size: 18px;
    }

    .flag {
        position: absolute;
        left: 40px;
        top: 140px;
        width: 280px;
        z-index: 1;
    }

    /* MOBILE */
    @@media (max-width: 768px) {

        body {
            overflow-x: hidden;
        }

        .join-card {
            width: 92%;
            padding: 25px;
            margin-top: 40px;
            border-radius: 20px;
        }

        .main-title {
            font-size: 42px;
        }

        .mini-text {
            font-size: 28px;
        }

        .sub-text {
            font-size: 16px;
        }

        .join-input {
            height: 50px;
            font-size: 18px;
        }

        .join-btn {
            height: 55px;
            font-size: 24px;
        }

        .flag {
            width: 120px;
            left: 10px;
            top: 80px;
            opacity: 0.9;
        }

        .left-wave,
        .right-wave {
            width: 300px;
            height: 300px;
        }
    }

</style>

<div class="main-bg">

    <div class="left-wave"></div>

    <div class="right-wave"></div>

</div>

<img class="flag"
     src="https://upload.wikimedia.org/wikipedia/commons/2/21/Flag_of_Vietnam.svg" />

<div class="join-card">

    <div style="font-size:70px;color:gold;">
        ★
    </div>

    <div class="mini-text">
        Mini Game
    </div>

    <div class="main-title">
        TƯ TƯỞNG <br />
        HỒ CHÍ MINH
    </div>

    <div class="sub-text">
        HỌC TẬP - HIỂU BIẾT - VẬN DỤNG
    </div>

    <form method="post" asp-action="Waiting">

        <input type="text"
               name="playerName"
               class="form-control join-input"
               placeholder="Nhập tên của bạn" />

        <button class="join-btn">
            THAM GIA
        </button>

    </form>

    <div class="footer-text">
        ĐOÀN KẾT - KỶ CƯƠNG - PHÁT TRIỂN
    </div>

</div>