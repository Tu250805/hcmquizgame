@model List<HCMQuizGame.Models.PlayerResult>

@{
    ViewData["Title"] = "Bảng Xếp Hạng";
}

<style>

    body {
        margin: 0;
        padding: 0;
        font-family: Arial;
        background: linear-gradient(rgba(120,0,0,0.9), rgba(80,0,0,0.92)), url('https://images.unsplash.com/photo-1521295121783-8a321d551ad2?q=80&w=2070');
        background-size: cover;
        background-position: center;
        min-height: 100vh;
        overflow-x: hidden;
    }

    * {
        box-sizing: border-box;
    }

    .leaderboard {
        width: 1200px;
        max-width: 95%;
        margin: auto;
        margin-top: 40px;
        background: rgba(255,255,255,0.95);
        border-radius: 40px;
        padding: 45px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.35);
        backdrop-filter: blur(12px);
        border: 4px solid rgba(255,215,0,0.25);
    }

    .title {
        text-align: center;
        font-size: 60px;
        font-weight: bold;
        color: #d40000;
        margin-bottom: 15px;
        text-shadow: 0 4px 15px rgba(255,0,0,0.2);
    }

    .sub-title {
        text-align: center;
        color: #777;
        font-size: 24px;
        margin-bottom: 40px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        overflow: hidden;
        border-radius: 25px;
        background: white;
    }

    th {
        background: linear-gradient(to right,#ff0000,#b30000);
        color: white;
        padding: 24px;
        font-size: 24px;
        letter-spacing: 1px;
    }

    td {
        padding: 22px;
        font-size: 24px;
        text-align: center;
        border-bottom: 1px solid #eee;
        transition: 0.3s;
    }

    tr {
        transition: 0.3s;
    }

        tr:hover {
            background: #fff5f5;
            transform: scale(1.01);
        }

    .gold {
        background: linear-gradient(135deg,#ffe066,#ffcc00);
        font-weight: bold;
        animation: glow 1.5s infinite;
    }

    .silver {
        background: linear-gradient(135deg,#eeeeee,#cccccc);
        font-weight: bold;
    }

    .bronze {
        background: linear-gradient(135deg,#ffcc99,#cc7a00);
        font-weight: bold;
    }

    @@keyframes glow {

        0% {
            box-shadow: 0 0 10px rgba(255,215,0,0.4);
        }

        50% {
            box-shadow: 0 0 30px rgba(255,215,0,0.8);
        }

        100% {
            box-shadow: 0 0 10px rgba(255,215,0,0.4);
        }
    }

    .champion {
        text-align: center;
        margin-bottom: 30px;
        font-size: 32px;
        color: #d40000;
        font-weight: bold;
    }

    .footer-text {
        margin-top: 35px;
        text-align: center;
        font-size: 24px;
        color: #c40000;
        font-weight: bold;
    }

    /* MOBILE */

    @@media (max-width: 768px) {

        body {
            overflow-x: hidden;
        }

        .leaderboard {
            width: 95%;
            padding: 20px;
            margin-top: 20px;
            border-radius: 25px;
        }

        .title {
            font-size: 34px;
            line-height: 1.3;
        }

        .sub-title {
            font-size: 16px;
            margin-bottom: 20px;
        }

        .champion {
            font-size: 22px;
            line-height: 1.5;
        }

        table {
            display: block;
            overflow-x: auto;
            white-space: nowrap;
            border-radius: 15px;
        }

        th {
            font-size: 16px;
            padding: 14px;
        }

        td {
            font-size: 16px;
            padding: 14px;
        }

        .footer-text {
            font-size: 18px;
            line-height: 1.5;
        }
    }

</style>

<div class="leaderboard">

    <div class="title">

        🏆 BẢNG XẾP HẠNG 🏆

    </div>

    <div class="sub-title">

        Mini Game Tư Tưởng Hồ Chí Minh 🇻🇳

    </div>

    @if (Model.Count > 0)
    {
        <div class="champion">

            👑 Quán quân hiện tại:
            <span style="color:#ff9900">

                @Model[0].PlayerName

            </span>

        </div>
    }

    <table>

        <tr>

            <th>Hạng</th>

            <th>Người Chơi</th>

            <th>Điểm</th>

            <th>Thời Gian</th>

        </tr>

        @for (int i = 0; i < Model.Count; i++)
        {
            string rowClass = "";

            if (i == 0)
            {
                rowClass = "gold";
            }
            else if (i == 1)
            {
                rowClass = "silver";
            }
            else if (i == 2)
            {
                rowClass = "bronze";
            }

            <tr class="@rowClass">

                <td>

                    @if (i == 0)
                    {
                        <text>🥇</text>
                    }
                    else if (i == 1)
                    {
                        <text>🥈</text>
                    }
                    else if (i == 2)
                    {
                        <text>🥉</text>
                    }
                    else
                    {
                        <text>#@(i + 1)</text>
                    }

                </td>

                <td>

                    @Model[i].PlayerName

                </td>

                <td>

                    @Model[i].Score

                </td>

                <td>

                    @Model[i].TimeUsed giây

                </td>

            </tr>
        }

    </table>

    <div class="footer-text">

        ⭐ Học tập và làm theo tư tưởng Hồ Chí Minh ⭐

    </div>

</div>